{
  "manifest_version": 3,
  "name": "Self-Harm Warning Bypass",
  "version": "1.0",
  "description": "Automatically bypasses the suicide/self-harm content warning",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "24": "icon24.png",
	  "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}